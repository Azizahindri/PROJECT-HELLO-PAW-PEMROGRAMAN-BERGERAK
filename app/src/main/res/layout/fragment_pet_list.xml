<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFA">

    <LinearLayout
        android:id="@+id/layout_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:background="@android:color/white"
        android:gravity="center"
        android:elevation="2dp">

        <TextView
            android:id="@+id/tv_title_daftar_hewan"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Daftar Hewan Saya"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#4FA0D0"
            android:fontFamily="sans-serif-medium" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pantau dan kelola kondisi hewan peliharaanmu"
            android:textSize="13sp"
            android:textColor="#777777"
            android:layout_marginTop="4dp"
            android:gravity="center" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_pet_list"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/layout_header"
        android:clipToPadding="false"
        android:paddingTop="8dp"
        android:paddingBottom="90dp"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        tools:listitem="@layout/item_pet"
        tools:itemCount="5" />

    <LinearLayout
        android:id="@+id/layout_empty_state"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/layout_header"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone"
        android:padding="20dp">

        <ImageView
            android:layout_width="150dp"
            android:layout_height="150dp"
            android:src="@android:drawable/stat_notify_more"
            android:contentDescription="Ikon Kosong"
            app:tint="#CCCCCC" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Belum ada hewan peliharaan,\nyuk tambahkan sekarang!"
            android:textAlignment="center"
            android:textSize="16sp"
            android:textColor="#999999"
            android:layout_marginTop="16dp" />
    </LinearLayout>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_add_pet"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_alignParentBottom="true"
        android:layout_margin="24dp"
        android:contentDescription="Tambah Hewan"
        app:backgroundTint="#4FA0D0"
        app:srcCompat="@android:drawable/ic_input_add"
        app:tint="@android:color/white"
        app:fabSize="normal" />

</RelativeLayout>