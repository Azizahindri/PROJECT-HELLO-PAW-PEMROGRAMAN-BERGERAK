<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:id="@+id/header_layout"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:background="#356187"
        android:elevation="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/iv_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/back"
            android:padding="8dp"
            android:src="@drawable/ic_arrow_back"
            app:tint="@color/white" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvChatName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Drh. Kaziya"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvChatSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Wednesday 13:30"
                android:textColor="#D4E8F2"
                android:textSize="12sp" />

        </LinearLayout>

        <TextView
            android:id="@+id/tvTimer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="30:00"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#FFEB3B"
            android:layout_marginEnd="8dp" />

        <ImageView
            android:id="@+id/iv_menu_dots"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/menu"
            android:padding="8dp"
            android:src="@drawable/ic_more_vert"
            app:tint="@color/white" />

    </LinearLayout>

    <TextView
        android:id="@+id/tvChatStatus"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:padding="12dp"
        android:gravity="center"
        android:text="✅ Konsultasi Selesai"
        android:textColor="#1B5E20"
        android:textSize="14sp"
        android:textStyle="bold"
        android:background="#E8F5E9"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/header_layout" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_chat"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@color/background"
        android:clipToPadding="false"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        app:layout_constraintBottom_toTopOf="@id/btnEndConsultation"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvChatStatus" />

    <Button
        android:id="@+id/btnEndConsultation"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Selesaikan Konsultasi"
        android:backgroundTint="#D32F2F"
        android:textColor="@android:color/white"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="8dp"
        android:visibility="gone"
        app:cornerRadius="12dp"
        app:layout_constraintBottom_toTopOf="@id/btnViewReview"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <Button
        android:id="@+id/btnBackToHome"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:text="🏠 Kembali ke Beranda"
        android:textColor="#FFFFFF"
        android:backgroundTint="#356187"
        android:visibility="gone"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="8dp"
        app:cornerRadius="12dp"
        app:layout_constraintBottom_toTopOf="@id/btnViewReview"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <Button
        android:id="@+id/btnViewReview"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:text="Beri Review"
        android:textSize="16sp"
        android:textColor="@android:color/white"
        android:backgroundTint="#356187"
        android:visibility="gone"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="8dp"
        app:cornerRadius="12dp"
        app:layout_constraintBottom_toTopOf="@id/input_area"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <LinearLayout
        android:id="@+id/input_area"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/surface"
        android:elevation="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <ImageButton
            android:id="@+id/btn_ai_suggest"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_input_icon_button"
            android:contentDescription="@string/ai_suggestion"
            android:padding="8dp"
            android:src="@drawable/ic_auto_awesome"
            app:tint="@color/accent" />

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_message"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:background="@drawable/bg_message_input"
            android:hint="@string/type_message"
            android:inputType="textMultiLine|textCapSentences"
            android:maxLines="5"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:textSize="15sp" />

        <ImageButton
            android:id="@+id/btn_send"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_send_button"
            android:contentDescription="@string/send"
            android:padding="10dp"
            android:src="@drawable/ic_send" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>