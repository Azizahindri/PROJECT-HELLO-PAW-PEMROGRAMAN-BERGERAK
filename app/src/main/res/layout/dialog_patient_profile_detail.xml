<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#F7FDFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#356187"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:id="@+id/tvDialogPatientTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Detail Profil Pasien"
                android:textColor="@android:color/white"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvDialogPatientSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Informasi pasien dan riwayat konsultasi"
                android:textColor="#C8E0F5"
                android:textSize="12sp"
                android:layout_marginTop="4dp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@android:color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Data Akun Pasien"
                        android:textColor="#356187"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvDialogPatientName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Nama: -"
                        android:textColor="#1A2D4E"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginTop="10dp" />

                    <TextView
                        android:id="@+id/tvDialogPatientEmail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Email: -"
                        android:textColor="#6B7C93"
                        android:textSize="13sp"
                        android:layout_marginTop="6dp" />

                    <TextView
                        android:id="@+id/tvDialogPatientPhone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="No. HP: -"
                        android:textColor="#6B7C93"
                        android:textSize="13sp"
                        android:layout_marginTop="4dp" />

                    <TextView
                        android:id="@+id/tvDialogPatientAddress"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Alamat: -"
                        android:textColor="#6B7C93"
                        android:textSize="13sp"
                        android:layout_marginTop="4dp" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@android:color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Hewan yang Dikonsultasikan"
                        android:textColor="#356187"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvDialogCurrentPet"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Anabul · Hewan"
                        android:textColor="#1A2D4E"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginTop="10dp" />

                    <TextView
                        android:id="@+id/tvDialogConsultationStatus"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Status konsultasi: -"
                        android:textColor="#6B7C93"
                        android:textSize="13sp"
                        android:layout_marginTop="6dp" />

                    <TextView
                        android:id="@+id/tvDialogReviewStatus"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Rating: -"
                        android:textColor="#6B7C93"
                        android:textSize="13sp"
                        android:layout_marginTop="4dp" />

                    <TextView
                        android:id="@+id/tvDialogConsultationDate"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Tanggal: -"
                        android:textColor="#6B7C93"
                        android:textSize="13sp"
                        android:layout_marginTop="4dp" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Card Daftar Hewan -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@android:color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Daftar Hewan Pasien"
                        android:textColor="#356187"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvDialogPatientPets"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Memuat data hewan..."
                        android:textColor="#6B7C93"
                        android:textSize="13sp"
                        android:lineSpacingExtra="4dp"
                        android:layout_marginTop="10dp" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Card Riwayat -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@android:color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Riwayat Konsultasi"
                        android:textColor="#356187"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvDialogPatientHistory"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Memuat riwayat konsultasi..."
                        android:textColor="#6B7C93"
                        android:textSize="13sp"
                        android:lineSpacingExtra="4dp"
                        android:layout_marginTop="10dp" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Tombol Tutup -->
            <TextView
                android:id="@+id/tvClosePatientDialog"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:gravity="center"
                android:text="Tutup"
                android:textColor="@android:color/white"
                android:textSize="15sp"
                android:textStyle="bold"
                android:background="#356187"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="4dp" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>