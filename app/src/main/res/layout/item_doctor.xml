<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="14dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="#FFFFFF">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="14dp">

        <!-- Foto Profil Bulat -->
        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/ivDoctorPhoto"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:src="@drawable/ic_launcher_foreground"
            app:civ_border_width="2dp"
            app:civ_border_color="#C8E0F5"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Nama Dokter -->
        <TextView
            android:id="@+id/tvDoctorName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="drh. Susianti"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#356187"
            app:layout_constraintTop_toTopOf="@id/ivDoctorPhoto"
            app:layout_constraintStart_toEndOf="@id/ivDoctorPhoto"
            app:layout_constraintEnd_toStartOf="@id/ivChatBtn"
            android:layout_marginStart="12dp"
            android:layout_marginTop="2dp" />

        <!-- Spesialisasi -->
        <TextView
            android:id="@+id/tvDoctorSpecialization"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Dokter Hewan Umum"
            android:textSize="12sp"
            android:textColor="#7A9EC0"
            app:layout_constraintTop_toBottomOf="@id/tvDoctorName"
            app:layout_constraintStart_toEndOf="@id/ivDoctorPhoto"
            app:layout_constraintEnd_toStartOf="@id/ivChatBtn"
            android:layout_marginStart="12dp"
            android:layout_marginTop="2dp" />

        <!-- Rating Bintang -->
        <RatingBar
            android:id="@+id/ratingBar"
            style="@style/Widget.AppCompat.RatingBar.Small"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:numStars="5"
            android:rating="4.5"
            android:stepSize="0.5"
            android:isIndicator="true"
            android:progressTint="#FFC107"
            app:layout_constraintTop_toBottomOf="@id/tvDoctorSpecialization"
            app:layout_constraintStart_toEndOf="@id/ivDoctorPhoto"
            android:layout_marginStart="12dp"
            android:layout_marginTop="4dp" />

        <!-- Jumlah ulasan -->
        <TextView
            android:id="@+id/tvReviewCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="5 Ulasan"
            android:textSize="11sp"
            android:textColor="#9BBBD4"
            app:layout_constraintTop_toBottomOf="@id/ratingBar"
            app:layout_constraintStart_toEndOf="@id/ivDoctorPhoto"
            android:layout_marginStart="12dp"
            android:layout_marginTop="2dp" />

        <!-- Tarif -->
        <TextView
            android:id="@+id/tvDoctorPrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Rp 50.000"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#356187"
            app:layout_constraintTop_toBottomOf="@id/tvReviewCount"
            app:layout_constraintStart_toEndOf="@id/ivDoctorPhoto"
            android:layout_marginStart="12dp"
            android:layout_marginTop="4dp" />

        <!-- Tombol Chat / Konsultasi (ikon bulat biru) -->
        <ImageView
            android:id="@+id/ivChatBtn"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:src="@android:drawable/ic_menu_send"
            android:tint="#356187"
            android:background="@drawable/bg_circle_blue"
            android:padding="8dp"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.cardview.widget.CardView>