<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Baris Atas: Nama Dokter + Status -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvHistoryDocName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="drh. Nama Dokter"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#356187" />

            <TextView
                android:id="@+id/tvHistoryStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🟢 Status"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Nama Hewan -->
        <TextView
            android:id="@+id/tvHistoryPetName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Hewan: Anabul"
            android:textSize="13sp"
            android:textColor="#757575" />

        <!-- Pesan Terakhir -->
        <TextView
            android:id="@+id/tvHistoryLastMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Pesan terakhir..."
            android:textSize="13sp"
            android:textColor="#757575"
            android:maxLines="1"
            android:ellipsize="end" />

        <!-- Durasi -->
        <TextView
            android:id="@+id/tvHistoryDuration"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Durasi: 15 menit"
            android:textSize="12sp"
            android:textColor="#757575"
            android:visibility="gone" />

        <!-- Tombol Review -->
        <Button
            android:id="@+id/btnRate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="⭐ Beri Review"
            android:textSize="12sp"
            android:textColor="@android:color/white"
            android:backgroundTint="#356187"
            android:visibility="gone"
            app:cornerRadius="8dp" />

    </LinearLayout>
</androidx.cardview.widget.CardView>