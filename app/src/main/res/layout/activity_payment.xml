<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#f0fcff">

    <!-- Toolbar biru navy -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbarPayment"
        android:layout_width="0dp"
        android:layout_height="?attr/actionBarSize"
        android:background="#356187"
        app:title="Ringkasan Pesanan"
        app:titleTextColor="#FFFFFF"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Card Ringkasan Pesanan -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardOrderSummary"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="16dp"
        app:cardCornerRadius="14dp"
        app:cardElevation="3dp"
        app:cardBackgroundColor="#FFFFFF"
        app:layout_constraintTop_toBottomOf="@id/toolbarPayment"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Detail Pesanan"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#356187" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#DAEAF8"
                android:layout_marginVertical="10dp" />

            <!-- Nama Layanan -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Layanan"
                    android:textSize="13sp"
                    android:textColor="#9BBBD4" />
                <TextView
                    android:id="@+id/tvServiceName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Konsultasi Online"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#356187" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Dokter"
                    android:textSize="13sp"
                    android:textColor="#9BBBD4" />
                <TextView
                    android:id="@+id/tvDoctorNamePayment"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="drh. Susianti"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#356187" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Metode Pembayaran"
                    android:textSize="13sp"
                    android:textColor="#9BBBD4" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="QRIS"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#356187" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#DAEAF8"
                android:layout_marginVertical="10dp" />

            <!-- Total -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Total hem bayaran"
                    android:textSize="13sp"
                    android:textColor="#9BBBD4" />
                <TextView
                    android:id="@+id/tvTotalAmount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Rp 305.000,00"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#356187" />
            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Card QRIS -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardQris"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="14dp"
        app:cardCornerRadius="14dp"
        app:cardElevation="3dp"
        app:cardBackgroundColor="#FFFFFF"
        app:layout_constraintTop_toBottomOf="@id/cardOrderSummary"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Scan QRIS untuk Membayar"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#356187" />

            <!-- Gambar QRIS statis -->
            <ImageView
                android:id="@+id/ivQrisCode"
                android:layout_width="200dp"
                android:layout_height="200dp"
                android:src="@drawable/qris_placeholder"
                android:scaleType="fitCenter"
                android:contentDescription="Kode QRIS Pembayaran"
                android:layout_marginTop="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Berlaku untuk semua e-wallet &amp; m-banking"
                android:textSize="11sp"
                android:textColor="#9BBBD4"
                android:layout_marginTop="8dp" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- ProgressBar loading (hidden by default) -->
    <ProgressBar
        android:id="@+id/progressBarPayment"
        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:indeterminate="true"
        android:progressTint="#356187"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/btnConfirmPayment"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="6dp" />

    <!-- Tombol SAYA SUDAH BAYAR -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnConfirmPayment"
        android:layout_width="0dp"
        android:layout_height="54dp"
        android:text="SAYA SUDAH BAYAR"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#356187"
        app:cornerRadius="14dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="32dp" />

</androidx.constraintlayout.widget.ConstraintLayout>