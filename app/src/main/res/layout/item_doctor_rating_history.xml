<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="@color/surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <TextView
            android:id="@+id/tvRatingPetName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Hewan: Anabul"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            android:textStyle="bold" />

        <RatingBar
            android:id="@+id/ratingBarDoctorHistory"
            style="?android:attr/ratingBarStyleSmall"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:numStars="5"
            android:stepSize="0.5"
            android:isIndicator="true"
            android:layout_marginTop="6dp"
            android:progressTint="#FFB800" />

        <TextView
            android:id="@+id/tvRatingComment"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Komentar pasien"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:layout_marginTop="6dp" />

        <TextView
            android:id="@+id/tvRatingTimestamp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tanggal review"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/tvReadRatingDetail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Lihat detail review"
            android:textColor="#356187"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp" />

    </LinearLayout>

</androidx.cardview.widget.CardView>