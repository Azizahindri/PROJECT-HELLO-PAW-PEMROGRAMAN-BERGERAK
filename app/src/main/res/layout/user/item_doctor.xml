<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="16dp"
    android:layout_marginEnd="16dp"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="#FFFFFF">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="14dp">

        <!-- Foto Profil Bulat -->
        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/ivDoctorPhoto"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/ic_launcher_foreground"
            app:civ_border_color="#A5D6A7"
            app:civ_border_width="2dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Indikator Online (dot hijau) -->
        <View
            android:id="@+id/viewOnlineIndicator"
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:background="@drawable/bg_online_dot"
            app:layout_constraintBottom_toBottomOf="@+id/ivDoctorPhoto"
            app:layout_constraintEnd_toEndOf="@+id/ivDoctorPhoto" />

        <!-- Nama Dokter -->
        <TextView
            android:id="@+id/tvDoctorName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_marginEnd="8dp"
            android:text="drh. Sarah Amelia"
            android:textColor="#1B5E20"
            android:textSize="15sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@+id/tvDoctorTarif"
            app:layout_constraintStart_toEndOf="@+id/ivDoctorPhoto"
            app:layout_constraintTop_toTopOf="@+id/ivDoctorPhoto" />

        <!-- Spesialisasi -->
        <TextView
            android:id="@+id/tvDoctorSpecialization"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_marginTop="4dp"
            android:layout_marginEnd="8dp"
            android:text="Spesialis Kucing & Anjing"
            android:textColor="#616161"
            android:textSize="12sp"
            app:layout_constraintEnd_toStartOf="@+id/tvDoctorTarif"
            app:layout_constraintStart_toEndOf="@+id/ivDoctorPhoto"
            app:layout_constraintTop_toBottomOf="@+id/tvDoctorName" />

        <!-- Rating -->
        <TextView
            android:id="@+id/tvDoctorRating"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_marginTop="4dp"
            android:text="⭐ 4.9 • 120 Konsultasi"
            android:textColor="#F57F17"
            android:textSize="11sp"
            app:layout_constraintEnd_toStartOf="@+id/tvDoctorTarif"
            app:layout_constraintStart_toEndOf="@+id/ivDoctorPhoto"
            app:layout_constraintTop_toBottomOf="@+id/tvDoctorSpecialization" />

        <!-- Tarif -->
        <TextView
            android:id="@+id/tvDoctorTarif"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_tarif_chip"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:text="Rp 50.000"
            android:textColor="#2E7D32"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@+id/ivDoctorPhoto"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/ivDoctorPhoto" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>