<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F9FBF9">

    <!-- AppBar dengan foto dokter -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="280dp"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar">

        <com.google.android.material.appbar.CollapsingToolbarLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:contentScrim="#2E7D32"
            app:layout_scrollFlags="scroll|exitUntilCollapsed"
            app:title="Profil Dokter"
            app:toolbarId="@+id/toolbarDetail">

            <!-- Foto Dokter Besar -->
            <ImageView
                android:id="@+id/ivDoctorDetailPhoto"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_launcher_foreground"
                app:layout_collapseMode="parallax"
                android:alpha="0.85" />

            <!-- Overlay gradient di bagian bawah foto -->
            <View
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:layout_gravity="bottom"
                android:background="@drawable/gradient_bottom_overlay"
                app:layout_collapseMode="parallax" />

            <androidx.appcompat.widget.Toolbar
                android:id="@+id/toolbarDetail"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                app:layout_collapseMode="pin"
                app:navigationIcon="@drawable/ic_arrow_back" />
        </com.google.android.material.appbar.CollapsingToolbarLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <!-- Konten Scrollable -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="80dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="20dp">

            <!-- Nama Dokter -->
            <TextView
                android:id="@+id/tvDetailDoctorName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="drh. Sarah Amelia, M.Sc"
                android:textColor="#1B5E20"
                android:textSize="22sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Spesialisasi -->
            <TextView
                android:id="@+id/tvDetailSpecialization"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Spesialis Kucing & Anjing"
                android:textColor="#388E3C"
                android:textSize="14sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/tvDetailDoctorName" />

            <!-- Info Cards: Pengalaman, Rating, Konsultasi -->
            <LinearLayout
                android:id="@+id/layoutInfoCards"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/tvDetailSpecialization">

                <!-- Pengalaman -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_info_card"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="12dp"
                    android:layout_marginEnd="6dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="5 Thn"
                        android:textColor="#2E7D32"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pengalaman"
                        android:textColor="#757575"
                        android:textSize="11sp" />
                </LinearLayout>

                <!-- Rating -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_info_card"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="12dp"
                    android:layout_marginStart="6dp"
                    android:layout_marginEnd="6dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⭐ 4.9"
                        android:textColor="#F57F17"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rating"
                        android:textColor="#757575"
                        android:textSize="11sp" />
                </LinearLayout>

                <!-- Konsultasi -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_info_card"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="12dp"
                    android:layout_marginStart="6dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="120+"
                        android:textColor="#2E7D32"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Konsultasi"
                        android:textColor="#757575"
                        android:textSize="11sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Biodata / Tentang -->
            <TextView
                android:id="@+id/tvSectionBio"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Tentang Dokter"
                android:textColor="#212121"
                android:textSize="16sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/layoutInfoCards" />

            <TextView
                android:id="@+id/tvDetailBio"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:lineSpacingExtra="4dp"
                android:text="drh. Sarah Amelia adalah dokter hewan berpengalaman yang telah menangani lebih dari 1200 pasien hewan peliharaan. Lulusan Fakultas Kedokteran Hewan Universitas Indonesia dengan spesialisasi pada kucing dan anjing ras."
                android:textColor="#424242"
                android:textSize="13sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/tvSectionBio" />

            <!-- Jam Praktik -->
            <TextView
                android:id="@+id/tvSectionJam"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="⏰  Jam Praktik"
                android:textColor="#212121"
                android:textSize="15sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/tvDetailBio" />

            <TextView
                android:id="@+id/tvDetailJamPraktik"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Senin – Jumat: 08.00 – 17.00 WIB\nSabtu: 08.00 – 13.00 WIB"
                android:textColor="#424242"
                android:textSize="13sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/tvSectionJam" />

            <!-- Tarif -->
            <TextView
                android:id="@+id/tvSectionTarif"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="💰  Tarif Konsultasi"
                android:textColor="#212121"
                android:textSize="15sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/tvDetailJamPraktik" />

            <TextView
                android:id="@+id/tvDetailTarif"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Rp 50.000 / sesi"
                android:textColor="#2E7D32"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/tvSectionTarif" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Tombol Mulai Konsultasi (Fixed di bawah) -->
    <Button
        android:id="@+id/btnStartConsultation"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:layout_gravity="bottom"
        android:layout_margin="16dp"
        android:backgroundTint="#2E7D32"
        android:text="💬  Mulai Konsultasi"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        app:cornerRadius="14dp" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>