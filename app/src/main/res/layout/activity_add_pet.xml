<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@android:color/white">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <LinearLayout
            android:id="@+id/layout_form"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="24dp">

                <ImageView
                    android:id="@+id/btn_add_pet_back"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_arrow_back"
                    app:tint="#4FA0D0"
                    android:contentDescription="Kembali" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Profile Hewan"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#4FA0D0"
                    android:layout_marginStart="12dp" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hewan Peliharaan"
                android:textColor="#4FA0D0"
                android:textStyle="bold"
                android:textSize="14sp"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/et_add_pet_category"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="contoh: Burung"
                android:background="@drawable/bg_input_profile_hewan"
                android:paddingHorizontal="20dp"
                android:textSize="14sp"
                android:inputType="text"
                android:importantForAutofill="no"
                android:layout_marginBottom="18dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Jenis Peliharaan"
                android:textColor="#4FA0D0"
                android:textStyle="bold"
                android:textSize="14sp"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/et_add_pet_type"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="contoh: Love Bird"
                android:background="@drawable/bg_input_profile_hewan"
                android:paddingHorizontal="20dp"
                android:textSize="14sp"
                android:inputType="text"
                android:importantForAutofill="no"
                android:layout_marginBottom="18dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nama Peliharaan"
                android:textColor="#4FA0D0"
                android:textStyle="bold"
                android:textSize="14sp"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/et_add_pet_name"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="contoh: Kicau"
                android:background="@drawable/bg_input_profile_hewan"
                android:paddingHorizontal="20dp"
                android:textSize="14sp"
                android:inputType="textPersonName"
                android:importantForAutofill="no"
                android:layout_marginBottom="18dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Usia"
                android:textColor="#4FA0D0"
                android:textStyle="bold"
                android:textSize="14sp"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/et_add_pet_age"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="contoh: 3 Tahun 10 Bulan"
                android:background="@drawable/bg_input_profile_hewan"
                android:paddingHorizontal="20dp"
                android:textSize="14sp"
                android:inputType="text"
                android:importantForAutofill="no"
                android:layout_marginBottom="20dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Jenis Kelamin"
                android:textColor="#4FA0D0"
                android:textStyle="bold"
                android:textSize="14sp"
                android:layout_marginBottom="6dp" />

            <RadioGroup
                android:id="@+id/rg_add_pet_gender"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="36dp">

                <RadioButton
                    android:id="@+id/rb_gender_jantan"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Jantan"
                    android:textColor="#333333"
                    android:layout_marginEnd="32dp" />

                <RadioButton
                    android:id="@+id/rb_gender_betina"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Betina"
                    android:textColor="#333333" />
            </RadioGroup>

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_add_pet_save"
                android:layout_width="220dp"
                android:layout_height="50dp"
                android:layout_gravity="center_horizontal"
                android:text="Simpan"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:background="@drawable/bg_button_profile_hewan" />

        </LinearLayout>

        <ImageView
            android:layout_width="85dp"
            android:layout_height="85dp"
            android:layout_below="@id/layout_form"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="30dp"
            android:layout_marginBottom="16dp"
            android:src="@drawable/ic_paw_print"
            android:contentDescription="Paw Icon Decor" />

    </RelativeLayout>
</ScrollView>