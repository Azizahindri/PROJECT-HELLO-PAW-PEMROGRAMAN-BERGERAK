<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/surface"
    android:orientation="vertical"
    android:padding="20dp">

    <!-- Handle Bar -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp"
        android:background="#E5E7EB" />

    <!-- Title -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_auto_awesome"
            android:tint="@color/accent" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="@string/ai_suggest_title"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/ai_suggest_tap"
            android:textColor="@color/text_secondary"
            android:textSize="11sp" />

    </LinearLayout>

    <!-- Suggestion 1 -->
    <TextView
        android:id="@+id/tv_suggest_1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:background="@drawable/bg_suggestion_item"
        android:foreground="?attr/selectableItemBackground"
        android:lineSpacingMultiplier="1.3"
        android:padding="14dp"
        android:text="@string/ai_suggest_1"
        android:textColor="@color/text_primary"
        android:textSize="14sp" />

    <!-- Suggestion 2 -->
    <TextView
        android:id="@+id/tv_suggest_2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:background="@drawable/bg_suggestion_item"
        android:foreground="?attr/selectableItemBackground"
        android:lineSpacingMultiplier="1.3"
        android:padding="14dp"
        android:text="@string/ai_suggest_2"
        android:textColor="@color/text_primary"
        android:textSize="14sp" />

    <!-- Suggestion 3 -->
    <TextView
        android:id="@+id/tv_suggest_3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:background="@drawable/bg_suggestion_item"
        android:foreground="?attr/selectableItemBackground"
        android:lineSpacingMultiplier="1.3"
        android:padding="14dp"
        android:text="@string/ai_suggest_3"
        android:textColor="@color/text_primary"
        android:textSize="14sp" />

</LinearLayout>