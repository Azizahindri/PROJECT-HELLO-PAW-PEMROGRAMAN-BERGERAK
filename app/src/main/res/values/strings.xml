    <!-- AI Suggestions (Medical) -->
    <string name="ai_fever_1">Berikan kompres hangat dan pastikan hewan minum air yang cukup.</string>
    <string name="ai_fever_2">Jika demam berlanjut lebih dari 24 jam, segera bawa ke klinik.</string>
    <string name="ai_fever_3">Berikan paracetamol khusus hewan sesuai dosis yang dianjurkan.</string>

    <string name="ai_vomit_1">Jangan diberi makan dulu selama 4-6 jam untuk mengistirahatkan lambung.</string>
    <string name="ai_vomit_2">Berikan air putih sedikit demi sedikit agar tidak dehidrasi.</string>
    <string name="ai_vomit_3">Amati apakah ada darah dalam muntahan, jika ada segera ke klinik.</string>

    <!-- AI Medical Suggestions - Additional -->
    <string name="ai_wound_1">Bersihkan luka dengan antiseptik yang aman untuk hewan.</string>
    <string name="ai_wound_2">Hindari hewan menjilat lukanya, gunakan cone collar jika perlu.</string>
    <string name="ai_wound_3">Jika luka dalam atau lebar, segera bawa ke klinik untuk dijahit.</string>

    <string name="ai_eating_1">Coba tawarkan makanan favoritnya atau makanan dengan aroma yang kuat.</string>
    <string name="ai_eating_2">Periksa apakah ada masalah pada gigi atau mulut.</string>
    <string name="ai_eating_3">Jika tidak mau makan lebih dari 2 hari, perlu pemeriksaan lebih lanjut.</string>

    <string name="ai_diarrhea_1">Berikan makanan yang mudah dicerna seperti nasi dan ayam rebus.</string>
    <string name="ai_diarrhea_2">Pastikan hewan tetap terhidrasi dengan minum air yang cukup.</string>
    <string name="ai_diarrhea_3">Berikan probiotik khusus hewan untuk membantu pemulihan.</string>

